{
    "indicators": {
        "Pred": {
            "type": "conditional_count",
            "frequency": "lta",
            "start_date": "04-21",
            "end_date": "05-31",
            "conditions": [
                {
                    "variable": "precip",
                    "operator": ">=",
                    "value": 0.1
                }
            ]
        },
        "N20-22": {
            "type": "conditional_count",
            "frequency": "lta",
            "start_date": "04-21",
            "end_date": "05-31",
            "conditions": [
                {
                    "variable": "tavg",
                    "operator": "between",
                    "value": [20, 22]
                }
            ]
        },
        "AT10": {
            "type": "growing_degree_days",
            "frequency": "lta",
            "start_date": "04-21",
            "end_date": "05-31"
        },
        "Tmin": {
            "type": "period_extreme",
            "frequency": "lta",
            "start_date": "04-21",
            "end_date": "05-31",
            "variable": "tmin"
        },
        "Ra": {
            "type": "total_radiation",
            "frequency": "lta",
            "start_date": "04-21",
            "end_date": "05-31"
        }
        },
    "formula": {
        "type": "custom_formula",
        "formula": "-0.4 * X1 + 0.2 * X2 - 0.4 * X4",
        "variables": {
            "X1": {
                "ref": "Pred"
            },
            "X2": {
                "ref": "N20-22"
            },
            "X3": {
                "ref": "AT10"
            },
            "X4": {
                "ref": "Tmin"
            },
            "X5": {
                "ref": "Ra"
            }
        }
    },
    "interpolation": {
        "method": "lsm_idw",
        "params": {
        "radius_dist": 10,
        "first_size": 100
        }
    },
    "classification": {
        "method": "natural_breaks",
        "num_classes": 4
    }
}

